# =============================================================================
# Application Configuration
# =============================================================================

# The environment the application is running in (development, staging, production)
NODE_ENV=development

# Port the application server listens on
PORT=3000

# Base URL of the application (used for generating links, callbacks, etc.)
APP_URL=http://localhost:3000

# =============================================================================
# Database Configuration
# =============================================================================

# Full database connection URL (takes precedence over individual DB_* variables)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test01

# Individual database connection parameters (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=test01

# =============================================================================
# Authentication & Security
# =============================================================================

# Secret key for signing JWT tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-secure-random-string

# JWT token expiration time (e.g., 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# Secret used for session encryption (use a long random string in production)
SESSION_SECRET=change-me-to-a-secure-random-string

# =============================================================================
# Logging
# =============================================================================

# Logging level (error, warn, info, debug, trace)
LOG_LEVEL=info

# =============================================================================
# External Services / API Keys
# =============================================================================

# Redis connection URL (used for caching, sessions, or queues)
REDIS_URL=redis://localhost:6379

# SMTP configuration for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# =============================================================================
# CORS & Allowed Origins
# =============================================================================

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000
